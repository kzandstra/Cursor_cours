      "parameters": {
        "jsCode": "let response = $json.text || $json.content || '';\n\n// Handle Claude structured response\nif (Array.isArray(response)) {\n  response = response.map(item => item.text || '').join('\\n');\n}\n\n// Ensure string\nif (typeof response !== 'string') {\n  response = JSON.stringify(response);\n}\n\nconst clean = response\n  .replace(/```json\\n?/g, '')\n  .replace(/```\\n?/g, '')\n  .trim();\n\ntry {\n  const parsed = JSON.parse(clean);\n  return { json: parsed };\n} catch (e) {\n  return { json: { text: response } };\n}"
      },
